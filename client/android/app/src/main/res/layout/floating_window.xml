<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_background"
    android:padding="10dp"
    android:elevation="8dp">

    <!-- 上方：运行指示 + 运行中 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 运行中指示 -->
        <View
            android:id="@+id/running_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/running_dot"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运行中"
            android:textColor="#10B981"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 下方：停止按钮 -->
    <LinearLayout
        android:id="@+id/stop_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/stop_button_background"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginTop="8dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_stop"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止运行"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 截图确认按钮（隐藏，流程需要时显示） -->
    <View
        android:id="@+id/screenshot_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:layout_marginTop="6dp"
        android:background="@drawable/screenshot_button_red"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>